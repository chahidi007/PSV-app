{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "noUnusedLocals": false,
    "noImplicitReturns": true,
    "outDir": "./dist"
  },
  "include": ["src/**/*.ts"]
}
