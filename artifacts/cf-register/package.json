{
  "name": "@workspace/cf-register",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create phytoclinic-users",
    "db:migrate:local": "wrangler d1 execute phytoclinic-users --local --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute phytoclinic-users --remote --file=./schema.sql",
    "db:list": "wrangler d1 list",
    "logs": "wrangler tail"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "wrangler": "^3.95.0"
  }
}
